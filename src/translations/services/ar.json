 "service5.tabContent": {
  "1": {
    "title": "الاكتشاف",
    "description": "نبدأ بفهم النطاق الكامل لرحلة العمل أو المنتج. يتضمن ذلك تحديد الأهداف، وتحليل المتطلبات، وفهم المستخدمين، وتحديد كيفية تطور الحل بمرور الوقت."
  },
  "2": {
    "title": "التصميم والهندسة المعمارية",
    "description": "استنادًا إلى نتائج الاكتشاف، نقوم بتصميم تجارب مستخدم سهلة وبناء أساس تقني قوي. نضمن أن يكون الحل قابلاً للتوسع وآمنًا ومرنًا لدعم التحسينات والتكاملات المستقبلية."
  },
  "3": {
    "title": "التطوير",
    "description": "يتم بناء الحل من خلال ممارسات تطوير منظمة ومرنة. نركز على تنفيذ الوظائف الأساسية وضمان الأداء والموثوقية والتوافق مع البنية المحددة."
  },
  "4": {
    "title": "النشر",
    "description": "قبل الإطلاق، يتم اختبار الحل بشكل شامل لضمان الاستقرار والجودة. بعد التحقق، يتم نشره في بيئة الإنتاج ليكون جاهزًا للاستخدام الفعلي."
  },
  "5": {
    "title": "التطور المستمر",
    "description": "بعد الإطلاق، نقدم دعمًا مستمرًا ومراقبة وتحسينات. ومع نمو احتياجات الأعمال، نُدخل الأتمتة وقدرات مدعومة بالذكاء الاصطناعي لتحسين العمليات وتعزيز الكفاءة."
  }
},
